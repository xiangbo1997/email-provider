# API Key for /api/mailbox-service/* and as fallback for /api/admin/*
EMAIL_PROVIDER_API_KEY=replace-with-a-long-random-secret

# Admin web login (required for /admin console and session-cookie mode)
EMAIL_PROVIDER_ADMIN_USERNAME=admin
# Generate with: python scripts/generate_admin_password_hash.py --password 'your-password'
EMAIL_PROVIDER_ADMIN_PASSWORD_HASH=
# Optional: admin web session ttl (seconds, default 28800 = 8h)
EMAIL_PROVIDER_ADMIN_SESSION_TTL_SECONDS=28800

# Data at-rest encryption for provider/session sensitive fields (32-byte base64url)
# Generate with: python scripts/generate_admin_password_hash.py --generate-data-key
EMAIL_PROVIDER_DATA_ENCRYPTION_KEY=
# Optional key rotation fallback
EMAIL_PROVIDER_DATA_ENCRYPTION_KEY_PREVIOUS=

# Runtime options
EMAIL_PROVIDER_EXPOSE_DOCS=0
EMAIL_PROVIDER_AUTH_DISABLED=0
EMAIL_PROVIDER_ADMIN_COOKIE_SECURE=0
EMAIL_PROVIDER_TRUST_PROXY_HEADERS=0
MAILBOX_SERVICE_DATABASE_URL=sqlite:////runtime/mailbox_service.db
